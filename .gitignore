# Create a new .gitignore without blocking notebooks
@"
# Data files - NEVER commit these!
data/raw/*.csv
data/raw/*.zip
*.csv
*.zip

# Jupyter Notebook checkpoints (but NOT the notebooks themselves)
.ipynb_checkpoints/
*/.ipynb_checkpoints/*

# Python
__pycache__/
*.py[cod]
*.pyc
venv/
.venv/
env/

# IDE
.vscode/
.idea/

# OS files
.DS_Store
Thumbs.db

# Logs
*.log
*.pid
"@ | Out-File -FilePath .gitignore -Encoding utf8

# Verify the fix
Get-Content .gitignore | Select-String "ipynb""bfg.jar" 
"data/" 
